{
  "name": "@skillmeat/backstage-plugin-scaffolder-backend",
  "version": "0.1.0",
  "description": "Backstage scaffolder backend module providing custom actions for SkillMeat (SAM) IDP integration",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "backstage": {
    "role": "backend-plugin-module",
