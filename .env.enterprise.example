# SkillMeat Enterprise Profile
# Copy to .env: cp .env.enterprise.example .env

# PostgreSQL connection (must match postgres service in docker-compose.yml)
DATABASE_URL=postgresql://skillmeat:skillmeat@postgres:5432/skillmeat
POSTGRES_PASSWORD=skillmeat

# API
SKILLMEAT_API_PORT=8080
SKILLMEAT_ENV=production

# Web
SKILLMEAT_WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://skillmeat-api:8080
