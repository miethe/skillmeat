# SkillMeat Enterprise Profile
# =====================================
# Profile: enterprise (PostgreSQL, Clerk auth, production settings)
# Edition: enterprise
# Backend: PostgreSQL
# Auth: enabled via Clerk (JWT validation)
#
# USAGE:
#   cp .env.enterprise.example .env
#   # Fill in all <REPLACE_WITH_*> placeholders before starting
#   docker compose up -d
#   # OR for bare-metal:
#   skillmeat web start
#
# This profile configures SkillMeat for multi-tenant enterprise deployment
# with a PostgreSQL backend, Clerk authentication, enterprise PAT support,
# and production-grade rate limiting and logging.
# DO NOT commit .env to source control.
# NEVER put real secrets in this file -- use placeholders only.

# ===================================================================
# ENVIRONMENT
# ===================================================================
SKILLMEAT_ENV=production
SKILLMEAT_EDITION=enterprise

# ===================================================================
# SERVER CONFIGURATION
# ===================================================================
# Bind to all interfaces when running inside a container
SKILLMEAT_HOST=0.0.0.0
SKILLMEAT_PORT=8080
SKILLMEAT_WORKERS=4
SKILLMEAT_RELOAD=false

# ===================================================================
# API CONFIGURATION
# ===================================================================
SKILLMEAT_API_VERSION=v1
SKILLMEAT_API_TITLE=SkillMeat API
SKILLMEAT_API_DESCRIPTION=REST API for SkillMeat collection manager - Enterprise

# ===================================================================
# CORS CONFIGURATION
# ===================================================================
SKILLMEAT_CORS_ENABLED=true
# Restrict to your production frontend domain -- no localhost origins
SKILLMEAT_CORS_ORIGINS=["https://skillmeat.example.com"]
SKILLMEAT_CORS_ALLOW_CREDENTIALS=true
SKILLMEAT_CORS_ALLOW_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
SKILLMEAT_CORS_ALLOW_HEADERS=["Authorization","Content-Type","X-Request-ID"]

# ===================================================================
# LOGGING CONFIGURATION
# ===================================================================
# JSON format for structured log ingestion (Loki, CloudWatch, Datadog, etc.)
SKILLMEAT_LOG_LEVEL=WARNING
SKILLMEAT_LOG_FORMAT=json

# ===================================================================
# COLLECTION CONFIGURATION
# ===================================================================
# Use a persistent volume path for artifact storage in containers
# SKILLMEAT_COLLECTION_DIR=/data/skillmeat/collections

# ===================================================================
# SECURITY
# ===================================================================
# Auth is ENABLED -- all API routes require a valid Clerk JWT.
SKILLMEAT_AUTH_ENABLED=true
SKILLMEAT_AUTH_PROVIDER=clerk

# Clerk JWT configuration -- all required when auth_provider=clerk.
# Find these in your Clerk dashboard under API Keys / JWT Templates.
#
# JWKS URL: where Clerk publishes its public signing keys.
# Format: https://<your-clerk-frontend-api>/.well-known/jwks.json
CLERK_JWKS_URL=<REPLACE_WITH_CLERK_JWKS_URL>
#
# Issuer: the iss claim expected in incoming JWTs.
# Format: https://<your-clerk-frontend-api>
CLERK_ISSUER=<REPLACE_WITH_CLERK_ISSUER>
#
# Audience: the aud claim expected in incoming JWTs (optional).
# Set this to your API identifier if configured in Clerk.
# CLERK_AUDIENCE=<REPLACE_WITH_CLERK_AUDIENCE>

# Enterprise PAT -- shared secret for authenticating enterprise service clients.
# Must be set before the enterprise download endpoint will accept requests.
# Primary env var; legacy ENTERPRISE_PAT_SECRET alias is deprecated.
SKILLMEAT_ENTERPRISE_PAT_SECRET=<REPLACE_WITH_ENTERPRISE_PAT_SECRET>

# API key auth (legacy) -- use Clerk Bearer tokens for new integrations
SKILLMEAT_API_KEY_ENABLED=false
# SKILLMEAT_API_KEY=<REPLACE_WITH_SECURE_KEY>

# ===================================================================
# RATE LIMITING
# ===================================================================
# Enable rate limiting in production to protect against abuse
SKILLMEAT_RATE_LIMIT_ENABLED=true
# Conservative limit for enterprise multi-tenant workloads
SKILLMEAT_RATE_LIMIT_REQUESTS=60

# ===================================================================
# DISCOVERY FEATURE FLAGS
# ===================================================================
SKILLMEAT_ENABLE_AUTO_DISCOVERY=true
SKILLMEAT_ENABLE_AUTO_POPULATION=true
SKILLMEAT_DISCOVERY_CACHE_TTL=3600

# GitHub API Token -- required in production to sustain 5000 req/hr rate limit
# SKILLMEAT_GITHUB_TOKEN=<REPLACE_WITH_GITHUB_PAT>

# ===================================================================
# FEATURE FLAGS
# ===================================================================
SKILLMEAT_COMPOSITE_ARTIFACTS_ENABLED=true
SKILLMEAT_DEPLOYMENT_SETS_ENABLED=true
SKILLMEAT_WORKFLOW_ENGINE_ENABLED=true
SKILLMEAT_MODULAR_CONTENT_ARCHITECTURE=false

# ===================================================================
# MEMORY & CONTEXT INTELLIGENCE SYSTEM
# ===================================================================
SKILLMEAT_MEMORY_CONTEXT_ENABLED=true
SKILLMEAT_MEMORY_AUTO_EXTRACT=false

# ===================================================================
# DATABASE (PostgreSQL)
# ===================================================================
# Full connection URL for the enterprise PostgreSQL backend.
# The skillmeat-api container reads this to connect to the postgres service.
DATABASE_URL=postgresql://skillmeat:skillmeat@postgres:5432/skillmeat

# PostgreSQL container credentials (used by the postgres service in docker-compose).
# Must match the username/password/db in DATABASE_URL above.
POSTGRES_USER=skillmeat
POSTGRES_PASSWORD=<REPLACE_WITH_POSTGRES_PASSWORD>
POSTGRES_DB=skillmeat

# ===================================================================
# WEB FRONTEND CONFIGURATION
# ===================================================================
# Internal API URL used by the Next.js container to reach the API service.
# In docker-compose, skillmeat-api is the service name.
NEXT_PUBLIC_API_URL=http://skillmeat-api:8080

# External port mappings for docker-compose (host:container)
# API accessible from host at: http://localhost:8080
# Web UI accessible from host at: http://localhost:3000
# API_PORT=8080
# WEB_PORT=3000

# Clerk publishable key for the Next.js frontend (from Clerk dashboard)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=<REPLACE_WITH_CLERK_PUBLISHABLE_KEY>

# ===================================================================
# OBSERVABILITY
# ===================================================================
# Prometheus metrics endpoint enabled at /metrics
# Grafana dashboard at http://grafana:3000 (internal) or your configured port
# Production alerting routed via Alertmanager

# ===================================================================
# EXTERNAL SERVICES
# ===================================================================
# PROMETHEUS_URL=http://prometheus:9090
# GRAFANA_URL=http://grafana:3000
# ALERTMANAGER_URL=http://alertmanager:9093

# ===================================================================
# NOTIFICATION HOOKS (for deployment alerts)
# ===================================================================
# SKILLMEAT_SLACK_WEBHOOK_URL=<REPLACE_WITH_SLACK_WEBHOOK>
# SKILLMEAT_ALERT_EMAIL=<REPLACE_WITH_OPS_EMAIL>

# ===================================================================
# NOTES
# ===================================================================
# - Replace ALL <REPLACE_WITH_*> placeholders before deploying
# - Use a secrets manager (HashiCorp Vault, AWS Secrets Manager, etc.) in production
# - NEVER commit real secrets, tokens, or API keys to source control
# - CLERK_JWKS_URL and CLERK_ISSUER are required when auth_provider=clerk
# - SKILLMEAT_ENTERPRISE_PAT_SECRET must be set for enterprise download endpoint
# - DATABASE_URL, POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB must all match
# - For local single-user setups, use .env.local.example instead
# - For local auth testing, use .env.local-auth.example instead
