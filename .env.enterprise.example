# SkillMeat — Enterprise (Production)
# PostgreSQL database with Clerk JWT authentication.
# Copy to .env: cp .env.enterprise.example .env
#
# Other profiles:
#   .env.example              — Zero-auth local dev (default)
#   .env.local-auth.example   — SQLite + API key auth (small teams)
#
# Guides:
#   docs/user/guides/server-setup.md#enterprise-edition-setup
#   docs/user/guides/authentication-setup.md#clerk-jwt-setup

# ── Server ────────────────────────────────────────────────────────────
SKILLMEAT_ENV=production
SKILLMEAT_EDITION=enterprise
SKILLMEAT_HOST=0.0.0.0
SKILLMEAT_PORT=8080
SKILLMEAT_WORKERS=4

# ── Logging ───────────────────────────────────────────────────────────
SKILLMEAT_LOG_LEVEL=INFO
SKILLMEAT_LOG_FORMAT=json

# ── Database (PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL=postgresql://skillmeat:CHANGE-ME@localhost:5432/skillmeat_db

# ── Authentication (Clerk JWT) ────────────────────────────────────────
SKILLMEAT_AUTH_ENABLED=true
SKILLMEAT_AUTH_PROVIDER=clerk
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-instance.clerk.accounts.dev
# CLERK_AUDIENCE=                      # Optional — set if your app requires audience validation

# ── Enterprise PAT (optional, for service-to-service auth) ────────────
# Generate with: openssl rand -hex 32
# SKILLMEAT_ENTERPRISE_PAT_SECRET=

# ── API Key (optional, for CI/CD alongside Clerk) ─────────────────────
# SKILLMEAT_API_KEY_ENABLED=true
# SKILLMEAT_API_KEY=CHANGE-ME

# ── Rate Limiting ─────────────────────────────────────────────────────
SKILLMEAT_RATE_LIMIT_ENABLED=true
SKILLMEAT_RATE_LIMIT_REQUESTS=100

# ── CORS (restrict to your frontend domain) ──────────────────────────
SKILLMEAT_CORS_ORIGINS=["https://skillmeat.example.com"]

# ── GitHub ────────────────────────────────────────────────────────────
# SKILLMEAT_GITHUB_TOKEN=ghp_your_token_here

# ── Feature Flags (all defaults — uncomment to override) ─────────────
# SKILLMEAT_ENABLE_AUTO_DISCOVERY=true
# SKILLMEAT_ENABLE_AUTO_POPULATION=true
# SKILLMEAT_COMPOSITE_ARTIFACTS_ENABLED=true
# SKILLMEAT_DEPLOYMENT_SETS_ENABLED=true
# SKILLMEAT_MEMORY_CONTEXT_ENABLED=true
# SKILLMEAT_WORKFLOW_ENGINE_ENABLED=true
