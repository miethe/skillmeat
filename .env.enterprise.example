# SkillMeat Enterprise Edition Configuration
# Copy to .env and fill in all required values
# Usage: docker compose --profile enterprise up -d

# Edition
SKILLMEAT_EDITION=enterprise

# Database (PostgreSQL - required for enterprise)
DATABASE_URL=postgresql://skillmeat:skillmeat@postgres:5432/skillmeat
POSTGRES_PASSWORD=skillmeat

# Auth provider
SKILLMEAT_AUTH_PROVIDER=clerk
CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_WEBHOOK_SECRET=whsec_...

# API Configuration
SKILLMEAT_API_PORT=8080
SKILLMEAT_API_HOST=0.0.0.0
# SKILLMEAT_WORKERS=4
# SKILLMEAT_CORS_ORIGINS=https://your-domain.com

# Web Configuration
SKILLMEAT_WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080

# PostgreSQL
POSTGRES_PORT=5432

# Logging
# SKILLMEAT_LOG_LEVEL=info

# Collection storage
# SKILLMEAT_COLLECTION_DIR=/home/app/.skillmeat/collections
