# SkillMeat Local Edition Configuration
# Copy to .env and customize as needed
# Usage: docker compose --profile local up -d

# Edition (local = SQLite, no auth required)
SKILLMEAT_EDITION=local

# API Configuration
SKILLMEAT_API_PORT=8080
SKILLMEAT_API_HOST=0.0.0.0

# Web Configuration
SKILLMEAT_WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080

# Collection storage (inside container, persisted via named volume)
# SKILLMEAT_COLLECTION_DIR=/home/app/.skillmeat/collections

# Logging
# SKILLMEAT_LOG_LEVEL=info
