# SkillMeat Local Development Profile
# =====================================
# Profile: local (SQLite, no auth, development settings)
# Edition: local
# Backend: SQLite (default, no DATABASE_URL needed)
# Auth: disabled (all requests authorized as local_admin)
#
# USAGE:
#   cp .env.local.example .env
#   skillmeat web dev
#
# This profile is for running SkillMeat on your local machine with the
# default SQLite backend and no authentication. Suitable for personal
# use and development work.
# DO NOT commit .env to source control.

# ===================================================================
# ENVIRONMENT
# ===================================================================
SKILLMEAT_ENV=development
SKILLMEAT_EDITION=local

# ===================================================================
# SERVER CONFIGURATION
# ===================================================================
# Bind to localhost only in development
SKILLMEAT_HOST=127.0.0.1
SKILLMEAT_PORT=8080
SKILLMEAT_WORKERS=1
# Enable auto-reload so code changes take effect immediately
SKILLMEAT_RELOAD=true

# ===================================================================
# API CONFIGURATION
# ===================================================================
SKILLMEAT_API_VERSION=v1
SKILLMEAT_API_TITLE=SkillMeat API (Local Dev)
SKILLMEAT_API_DESCRIPTION=REST API for SkillMeat collection manager - Local Development

# ===================================================================
# CORS CONFIGURATION
# ===================================================================
SKILLMEAT_CORS_ENABLED=true
SKILLMEAT_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:5173","http://localhost:8080"]
SKILLMEAT_CORS_ALLOW_CREDENTIALS=true
SKILLMEAT_CORS_ALLOW_METHODS=["*"]
SKILLMEAT_CORS_ALLOW_HEADERS=["*"]

# ===================================================================
# LOGGING CONFIGURATION
# ===================================================================
# Use text format for readable local logs; switch to json for log parsing
SKILLMEAT_LOG_LEVEL=DEBUG
SKILLMEAT_LOG_FORMAT=text

# ===================================================================
# COLLECTION CONFIGURATION
# ===================================================================
# Defaults to ~/.skillmeat/collections -- uncomment to override
# SKILLMEAT_COLLECTION_DIR=/path/to/custom/collections

# ===================================================================
# SECURITY
# ===================================================================
# Auth is disabled in local dev: all requests run as local_admin (no credentials needed)
SKILLMEAT_AUTH_ENABLED=false
SKILLMEAT_AUTH_PROVIDER=local

# API key auth is disabled by default for local dev
SKILLMEAT_API_KEY_ENABLED=false
# SKILLMEAT_API_KEY=<REPLACE_WITH_SECURE_KEY>

# ===================================================================
# RATE LIMITING
# ===================================================================
# Disable rate limiting in local dev to avoid throttling during testing
SKILLMEAT_RATE_LIMIT_ENABLED=false
SKILLMEAT_RATE_LIMIT_REQUESTS=100

# ===================================================================
# DISCOVERY FEATURE FLAGS
# ===================================================================
SKILLMEAT_ENABLE_AUTO_DISCOVERY=true
SKILLMEAT_ENABLE_AUTO_POPULATION=true
SKILLMEAT_DISCOVERY_CACHE_TTL=3600

# GitHub API Token -- optional but strongly recommended to avoid 60 req/hr rate limit
# Unauthenticated: 60 req/hr | Authenticated: 5000 req/hr
# SKILLMEAT_GITHUB_TOKEN=<REPLACE_WITH_GITHUB_PAT>

# ===================================================================
# FEATURE FLAGS
# ===================================================================
SKILLMEAT_COMPOSITE_ARTIFACTS_ENABLED=true
SKILLMEAT_DEPLOYMENT_SETS_ENABLED=true
SKILLMEAT_WORKFLOW_ENGINE_ENABLED=true
SKILLMEAT_MODULAR_CONTENT_ARCHITECTURE=false

# ===================================================================
# MEMORY & CONTEXT INTELLIGENCE SYSTEM
# ===================================================================
SKILLMEAT_MEMORY_CONTEXT_ENABLED=true
SKILLMEAT_MEMORY_AUTO_EXTRACT=false

# ===================================================================
# DATABASE
# ===================================================================
# SQLite is the default backend -- no DATABASE_URL needed.
# DB is stored at ~/.skillmeat/cache/skillmeat.db
# Uncomment to use a custom collection directory:
# SKILLMEAT_COLLECTION_DIR=~/.skillmeat/collections

# ===================================================================
# WEB FRONTEND CONFIGURATION
# ===================================================================
# Next.js frontend environment variables
NEXT_PUBLIC_API_URL=http://localhost:8080
# Port for the Next.js dev server (default: 3000)
# PORT=3000

# ===================================================================
# OBSERVABILITY
# ===================================================================
# Prometheus metrics available at http://localhost:8080/metrics
# No external observability stack needed for local dev

# ===================================================================
# EXTERNAL SERVICES
# ===================================================================
# Uncomment if running a local observability stack
# PROMETHEUS_URL=http://localhost:9090
# GRAFANA_URL=http://localhost:3001

# ===================================================================
# NOTES
# ===================================================================
# - SQLite backend requires no additional services
# - Auth is disabled: LocalAuthProvider grants all requests local_admin access
# - Set SKILLMEAT_GITHUB_TOKEN to avoid GitHub API rate limiting (60 req/hr)
# - For auth testing, use .env.local-auth.example instead
# - For PostgreSQL/enterprise features, use .env.enterprise.example instead
