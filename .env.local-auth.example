# SkillMeat Local + Clerk Auth Profile
# =====================================
# Profile: local-auth (SQLite, Clerk authentication enabled)
# Edition: local
# Backend: SQLite (default, no DATABASE_URL needed)
# Auth: enabled via Clerk (JWT validation)
#
# USAGE:
#   cp .env.local-auth.example .env
#   # Fill in CLERK_JWKS_URL and CLERK_ISSUER from your Clerk dashboard
#   skillmeat web dev
#
# This profile enables Clerk-based JWT authentication on top of the default
# SQLite backend. Use this when testing auth flows locally or when you want
# a local instance that mirrors a production auth configuration.
# Requires a Clerk application -- see https://clerk.com
# DO NOT commit .env to source control.

# ===================================================================
# ENVIRONMENT
# ===================================================================
SKILLMEAT_ENV=development
SKILLMEAT_EDITION=local

# ===================================================================
# SERVER CONFIGURATION
# ===================================================================
SKILLMEAT_HOST=127.0.0.1
SKILLMEAT_PORT=8080
SKILLMEAT_WORKERS=1
SKILLMEAT_RELOAD=true

# ===================================================================
# API CONFIGURATION
# ===================================================================
SKILLMEAT_API_VERSION=v1
SKILLMEAT_API_TITLE=SkillMeat API (Local + Auth)
SKILLMEAT_API_DESCRIPTION=REST API for SkillMeat collection manager - Local Development with Auth

# ===================================================================
# CORS CONFIGURATION
# ===================================================================
SKILLMEAT_CORS_ENABLED=true
SKILLMEAT_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:5173","http://localhost:8080"]
SKILLMEAT_CORS_ALLOW_CREDENTIALS=true
SKILLMEAT_CORS_ALLOW_METHODS=["*"]
SKILLMEAT_CORS_ALLOW_HEADERS=["*"]

# ===================================================================
# LOGGING CONFIGURATION
# ===================================================================
SKILLMEAT_LOG_LEVEL=DEBUG
SKILLMEAT_LOG_FORMAT=text

# ===================================================================
# COLLECTION CONFIGURATION
# ===================================================================
# Defaults to ~/.skillmeat/collections -- uncomment to override
# SKILLMEAT_COLLECTION_DIR=/path/to/custom/collections

# ===================================================================
# SECURITY
# ===================================================================
# Auth is ENABLED -- all API routes require a valid Clerk JWT.
# The LocalAuthProvider fallback is bypassed when auth_enabled=true.
SKILLMEAT_AUTH_ENABLED=true
SKILLMEAT_AUTH_PROVIDER=clerk

# Clerk JWT configuration -- all three values are required when auth_provider=clerk.
# Find these in your Clerk dashboard under API Keys / JWT Templates.
#
# JWKS URL: where Clerk publishes its public signing keys.
# Format: https://<your-clerk-frontend-api>/.well-known/jwks.json
CLERK_JWKS_URL=<REPLACE_WITH_CLERK_JWKS_URL>
#
# Issuer: the iss claim expected in incoming JWTs.
# Format: https://<your-clerk-frontend-api>
CLERK_ISSUER=<REPLACE_WITH_CLERK_ISSUER>
#
# Audience: the aud claim expected in incoming JWTs (optional).
# Set this to your API identifier if you configured one in Clerk.
# Leave commented out if not using audience validation.
# CLERK_AUDIENCE=<REPLACE_WITH_CLERK_AUDIENCE>

# API key auth (legacy) -- disabled; use Clerk Bearer tokens instead
SKILLMEAT_API_KEY_ENABLED=false
# SKILLMEAT_API_KEY=<REPLACE_WITH_SECURE_KEY>

# ===================================================================
# RATE LIMITING
# ===================================================================
# Keep rate limiting off for local auth testing to avoid interference
SKILLMEAT_RATE_LIMIT_ENABLED=false
SKILLMEAT_RATE_LIMIT_REQUESTS=100

# ===================================================================
# DISCOVERY FEATURE FLAGS
# ===================================================================
SKILLMEAT_ENABLE_AUTO_DISCOVERY=true
SKILLMEAT_ENABLE_AUTO_POPULATION=true
SKILLMEAT_DISCOVERY_CACHE_TTL=3600

# GitHub API Token -- optional but recommended (5000 req/hr vs 60 req/hr unauthenticated)
# SKILLMEAT_GITHUB_TOKEN=<REPLACE_WITH_GITHUB_PAT>

# ===================================================================
# FEATURE FLAGS
# ===================================================================
SKILLMEAT_COMPOSITE_ARTIFACTS_ENABLED=true
SKILLMEAT_DEPLOYMENT_SETS_ENABLED=true
SKILLMEAT_WORKFLOW_ENGINE_ENABLED=true
SKILLMEAT_MODULAR_CONTENT_ARCHITECTURE=false

# ===================================================================
# MEMORY & CONTEXT INTELLIGENCE SYSTEM
# ===================================================================
SKILLMEAT_MEMORY_CONTEXT_ENABLED=true
SKILLMEAT_MEMORY_AUTO_EXTRACT=false

# ===================================================================
# DATABASE
# ===================================================================
# SQLite is the default backend -- no DATABASE_URL needed.
# DB is stored at ~/.skillmeat/cache/skillmeat.db

# ===================================================================
# WEB FRONTEND CONFIGURATION
# ===================================================================
NEXT_PUBLIC_API_URL=http://localhost:8080
# Port for the Next.js dev server (default: 3000)
# PORT=3000

# Clerk publishable key for the Next.js frontend (from Clerk dashboard)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=<REPLACE_WITH_CLERK_PUBLISHABLE_KEY>

# ===================================================================
# OBSERVABILITY
# ===================================================================
# Prometheus metrics available at http://localhost:8080/metrics

# ===================================================================
# EXTERNAL SERVICES
# ===================================================================
# Uncomment if running a local observability stack
# PROMETHEUS_URL=http://localhost:9090
# GRAFANA_URL=http://localhost:3001

# ===================================================================
# NOTES
# ===================================================================
# - CLERK_JWKS_URL and CLERK_ISSUER are required when auth_provider=clerk
# - All /api/v1/* routes require a valid Clerk JWT (Authorization: Bearer <token>)
# - Excluded paths (no auth required): /health, /docs, /openapi.json, /api/v1/version
# - To disable auth and return to no-credential local dev, use .env.local.example instead
# - SQLite backend requires no additional services
# - Set SKILLMEAT_GITHUB_TOKEN to avoid GitHub API rate limiting (60 req/hr)
