# SkillMeat Local Edition with Authentication
# Copy to .env and fill in Clerk credentials
# Usage: docker compose --profile local-auth up -d

# Edition
SKILLMEAT_EDITION=local

# Auth provider (clerk is the only supported provider currently)
SKILLMEAT_AUTH_PROVIDER=clerk

# Clerk Configuration (required)
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_WEBHOOK_SECRET=whsec_...

# API Configuration
SKILLMEAT_API_PORT=8080
SKILLMEAT_API_HOST=0.0.0.0

# Web Configuration
SKILLMEAT_WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080

# Collection storage
# SKILLMEAT_COLLECTION_DIR=/home/app/.skillmeat/collections

# Logging
# SKILLMEAT_LOG_LEVEL=info
