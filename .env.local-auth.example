# SkillMeat — Local + Authentication (Small Teams)
# SQLite database with API key authentication.
# Copy to .env: cp .env.local-auth.example .env
#
# Other profiles:
#   .env.example              — Zero-auth local dev (default)
#   .env.enterprise.example   — PostgreSQL + Clerk JWT (production)
#
# Guide: docs/user/guides/authentication-setup.md

# ── Server ────────────────────────────────────────────────────────────
SKILLMEAT_ENV=development
SKILLMEAT_HOST=127.0.0.1
SKILLMEAT_PORT=8080
SKILLMEAT_RELOAD=true

# ── Logging ───────────────────────────────────────────────────────────
SKILLMEAT_LOG_LEVEL=INFO
SKILLMEAT_LOG_FORMAT=text

# ── Authentication ────────────────────────────────────────────────────
SKILLMEAT_AUTH_ENABLED=true
SKILLMEAT_AUTH_PROVIDER=local
SKILLMEAT_API_KEY_ENABLED=true
SKILLMEAT_API_KEY=CHANGE-ME-generate-with-openssl-rand-hex-32

# ── Rate Limiting (recommended when auth is enabled) ──────────────────
SKILLMEAT_RATE_LIMIT_ENABLED=true
SKILLMEAT_RATE_LIMIT_REQUESTS=100

# ── GitHub (optional) ─────────────────────────────────────────────────
# SKILLMEAT_GITHUB_TOKEN=ghp_your_token_here

# ── CORS (restrict if frontend is on a known host) ────────────────────
# SKILLMEAT_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ── Feature Flags (all defaults — uncomment to override) ─────────────
# SKILLMEAT_ENABLE_AUTO_DISCOVERY=true
# SKILLMEAT_ENABLE_AUTO_POPULATION=true
# SKILLMEAT_COMPOSITE_ARTIFACTS_ENABLED=true
# SKILLMEAT_DEPLOYMENT_SETS_ENABLED=true
# SKILLMEAT_MEMORY_CONTEXT_ENABLED=true
# SKILLMEAT_WORKFLOW_ENGINE_ENABLED=true
